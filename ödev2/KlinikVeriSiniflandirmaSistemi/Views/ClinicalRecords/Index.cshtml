@model IEnumerable<ClinicalRecord>

@{
    ViewData["Title"] = "Klinik Kayıtlar";
}

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Sınıf</label>
                <select name="classId" asp-items="ViewBag.ClassId" class="form-select">
                    <option value="">Tüm sınıflar</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Risk Seviyesi</label>
                <select name="riskLevel" asp-items="ViewBag.RiskLevel" class="form-select">
                    <option value="">Tüm riskler</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Başlangıç</label>
                <input type="date" name="startDate" value="@ViewData["StartDate"]" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Bitiş</label>
                <input type="date" name="endDate" value="@ViewData["EndDate"]" class="form-control" />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary" type="submit">Filtrele</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Temizle</a>
            </div>
        </form>
    </div>
</div>

<div class="card table-card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h2 class="h5 mb-0">Kayıt Listesi</h2>
        <a asp-action="Create" class="btn btn-success">Yeni Klinik Kayıt</a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Hasta</th>
                    <th>Şikayet</th>
                    <th>Tanı</th>
                    <th>Değerler</th>
                    <th>Sınıf</th>
                    <th>Tarih</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var color = item.ClinicalClass?.ColorCode == "orange" ? "badge-orange" : $"text-bg-{item.ClinicalClass?.ColorCode ?? "secondary"}";
                    <tr>
                        <td>@(item.Patient?.FirstName) @(item.Patient?.LastName)</td>
                        <td>@item.Complaint</td>
                        <td>@item.Diagnosis</td>
                        <td class="small">
                            TA: @item.SystolicBloodPressure/@item.DiastolicBloodPressure<br />
                            Nabız: @item.Pulse, Ateş: @item.BodyTemperature
                        </td>
                        <td><span class="badge @color">@item.ClinicalClass?.Name</span></td>
                        <td>@item.RecordDate.ToString("dd.MM.yyyy")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Detay</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
