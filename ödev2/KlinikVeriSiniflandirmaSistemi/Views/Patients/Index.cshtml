@model IEnumerable<Patient>

@{
    ViewData["Title"] = "Hastalar";
}

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-8">
                <label class="form-label">Hasta adı, soyadı veya hasta no</label>
                <input type="text" name="search" value="@ViewData["Search"]" class="form-control" placeholder="Örn: Ayşe, Yılmaz, 10000000001" />
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button class="btn btn-primary" type="submit">Ara</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Temizle</a>
                <a asp-action="Create" class="btn btn-success ms-auto">Yeni Hasta</a>
            </div>
        </form>
    </div>
</div>

<div class="card table-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Hasta</th>
                    <th>Hasta No</th>
                    <th>Doğum Tarihi</th>
                    <th>Telefon</th>
                    <th>Kayıt Sayısı</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FirstName @item.LastName</td>
                        <td>@item.PatientNumber</td>
                        <td>@item.BirthDate.ToString("dd.MM.yyyy")</td>
                        <td>@item.Phone</td>
                        <td><span class="badge text-bg-info">@item.ClinicalRecords.Count</span></td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Detay</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
