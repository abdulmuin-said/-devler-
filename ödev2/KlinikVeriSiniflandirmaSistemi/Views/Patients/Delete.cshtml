@model Patient

@{
    ViewData["Title"] = "Hasta Sil";
}

<div class="card border-danger">
    <div class="card-body">
        <h2 class="h5 text-danger">Bu hastayı silmek istiyor musunuz?</h2>
        <p>@Model.FirstName @Model.LastName hastası ve hastaya bağlı @Model.ClinicalRecords.Count klinik kayıt silinecek.</p>
        <form asp-action="Delete" method="post" class="d-flex gap-2">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Sil</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Vazgeç</a>
        </form>
    </div>
</div>
