@model KlinikVeriSiniflandirmaSistemi.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card p-3">
            <span class="text-muted">Toplam Hasta</span>
            <strong class="display-6">@Model.TotalPatients</strong>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card p-3">
            <span class="text-muted">Klinik Kayıt</span>
            <strong class="display-6">@Model.TotalClinicalRecords</strong>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card p-3">
            <span class="text-muted">Riskli Kayıt</span>
            <strong class="display-6 text-warning">@Model.RiskyCount</strong>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card p-3">
            <span class="text-muted">Acil Kayıt</span>
            <strong class="display-6 text-danger">@Model.EmergencyCount</strong>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    @foreach (var item in Model.ClassStatistics)
    {
        var badgeClass = item.ColorCode == "orange" ? "badge-orange" : $"text-bg-{item.ColorCode}";
        <div class="col-md-6 col-xl-3">
            <div class="card p-3 h-100">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h2 class="h6 mb-1">@item.ClassName</h2>
                        <span class="text-muted small">@item.RiskLevel</span>
                    </div>
                    <span class="badge @badgeClass">@item.Count</span>
                </div>
            </div>
        </div>
    }
</div>

<div class="card table-card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h2 class="h5 mb-0">Son Eklenen Klinik Kayıtlar</h2>
        <a asp-controller="ClinicalRecords" asp-action="Create" class="btn btn-primary btn-sm">Yeni Kayıt</a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Hasta</th>
                    <th>Tanı</th>
                    <th>Sınıf</th>
                    <th>Kayıt Tarihi</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.LatestClinicalRecords)
                {
                    var color = item.ClinicalClass?.ColorCode == "orange" ? "badge-orange" : $"text-bg-{item.ClinicalClass?.ColorCode ?? "secondary"}";
                    <tr>
                        <td>@(item.Patient?.FirstName) @(item.Patient?.LastName)</td>
                        <td>@item.Diagnosis</td>
                        <td><span class="badge @color">@item.ClinicalClass?.Name</span></td>
                        <td>@item.RecordDate.ToString("dd.MM.yyyy")</td>
                        <td class="text-end">
                            <a asp-controller="ClinicalRecords" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Detay</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
