<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Keylogger Tespit Sistemi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KeyloggerTespitSistemi.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Dashboard" asp-action="Index">Defensive Malware Analysis</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Analysis" asp-action="Create">Yeni Analiz</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Analysis" asp-action="Index">Analiz Listesi</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Reports" asp-action="Index">Raporlar</a></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="DetectionRules" asp-action="Index">Detection Rules</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Users" asp-action="Index">Kullanıcılar</a></li>
                            }
                        }
                        <li class="nav-item"><a class="nav-link" asp-controller="Ethics" asp-action="Index">Etik Kullanım</a></li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><span class="navbar-text text-white-50 me-2">@User.Identity.Name</span></li>
                            <li class="nav-item"><a class="btn btn-outline-light btn-sm" asp-controller="Auth" asp-action="Logout">Çıkış</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="btn btn-primary btn-sm" asp-controller="Auth" asp-action="Login">Giriş</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Keylogger Tespit Sistemi - Sadece savunma amaçlı manuel veri analizi.
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
