@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Dashboard</h1>
        <p class="text-muted mb-0">Manuel process raporlarına göre savunma amaçlı risk özeti.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Analysis" asp-action="Create">Yeni Analiz</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="metric-card"><span>Toplam Analiz</span><strong>@Model.TotalAnalyses</strong></div></div>
    <div class="col-md-3"><div class="metric-card success"><span>Düşük Risk</span><strong>@Model.LowRiskCount</strong></div></div>
    <div class="col-md-3"><div class="metric-card warning"><span>Orta Risk</span><strong>@Model.MediumRiskCount</strong></div></div>
    <div class="col-md-3"><div class="metric-card danger"><span>Yüksek Risk</span><strong>@Model.HighRiskCount</strong></div></div>
</div>

<div class="card">
    <div class="card-header bg-white fw-semibold">Son Analizler</div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead><tr><th>Process</th><th>Dosya Yolu</th><th>Risk</th><th>Puan</th><th>Tarih</th><th></th></tr></thead>
            <tbody>
            @foreach (var report in Model.RecentReports)
            {
                <tr>
                    <td>@report.ProcessName</td>
                    <td class="text-truncate path-cell">@report.FilePath</td>
                    <td><span class="badge @report.AnalysisResult?.RiskLevel.GetBadgeClass()">@report.AnalysisResult?.RiskLevel.GetDisplayName()</span></td>
                    <td>@report.AnalysisResult?.TotalScore</td>
                    <td>@report.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td><a class="btn btn-sm btn-outline-primary" asp-controller="Analysis" asp-action="Details" asp-route-id="@report.Id">Detay</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
