@model List<User>
@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Kullanıcı Yönetimi</h1>
    <a class="btn btn-primary" asp-action="Create">Yeni Kullanıcı</a>
</div>

<div class="table-responsive card">
    <table class="table table-hover align-middle mb-0">
        <thead><tr><th>Ad Soyad</th><th>E-posta</th><th>Rol</th><th>Durum</th><th>Oluşturma</th><th></th></tr></thead>
        <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>@user.Role?.Name</td>
                <td><span class="badge @(user.IsActive ? "text-bg-success" : "text-bg-secondary")">@(user.IsActive ? "Aktif" : "Pasif")</span></td>
                <td>@user.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                <td class="text-end">
                    @if (user.Id != 1)
                    {
                        <form asp-action="Toggle" asp-route-id="@user.Id" method="post" class="d-inline">
                            <button class="btn btn-sm btn-outline-secondary" type="submit">Aktif/Pasif</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
