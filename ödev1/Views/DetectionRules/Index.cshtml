@model List<DetectionRule>
@{
    ViewData["Title"] = "Detection Rules";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">Detection Rules Yönetimi</h1>
        <p class="text-muted mb-0">Risk puanını belirleyen savunma amaçlı kurallar.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Yeni Kural</a>
</div>

<div class="table-responsive card">
    <table class="table table-hover align-middle mb-0">
        <thead><tr><th>Kural</th><th>Tip</th><th>Puan</th><th>Durum</th><th></th></tr></thead>
        <tbody>
        @foreach (var rule in Model)
        {
            <tr>
                <td><strong>@rule.Name</strong><br /><span class="text-muted small">@rule.Description</span></td>
                <td>@rule.RuleType</td>
                <td>@rule.RiskPoint</td>
                <td><span class="badge @(rule.IsActive ? "text-bg-success" : "text-bg-secondary")">@(rule.IsActive ? "Aktif" : "Pasif")</span></td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@rule.Id">Düzenle</a>
                    <form asp-action="Toggle" asp-route-id="@rule.Id" method="post" class="d-inline">
                        <button class="btn btn-sm btn-outline-secondary" type="submit">Aktif/Pasif</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
